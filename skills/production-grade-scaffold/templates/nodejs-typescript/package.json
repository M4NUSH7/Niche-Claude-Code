    "ioredis": "^5.4.0",
    "@prisma/client": "^5.16.0",
    "pino": "^9.2.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^1.6.0",
    "eslint": "^9.5.0",
    "prisma": "^5.16.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/cors": "^2.8.17"
  }
