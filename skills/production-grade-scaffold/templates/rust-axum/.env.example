ENVIRONMENT=development
PORT=8080

# Database (see references/database.md — size pool via Little's Law, don't guess)
DATABASE_URL=postgres://user:password@localhost:5432/app_db
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_ACQUIRE_TIMEOUT_S=2

# Redis (rate limiting state + BFF session/token cache, see references/auth.md)
REDIS_URL=redis://localhost:6379

# Auth (BFF pattern: tokens live server-side, browser only gets a session cookie)
OAUTH_ISSUER=https://your-idp.example.com
OAUTH_CLIENT_ID=change-me
OAUTH_CLIENT_SECRET=change-me
SESSION_COOKIE_SECRET=change-me-32-bytes-min
JWKS_URI=https://your-idp.example.com/.well-known/jwks.json

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
RUST_LOG=info
