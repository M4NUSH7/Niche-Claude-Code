ENVIRONMENT=development
PORT=8000

# Database (see database/ layer — never commit real credentials)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/app_db

# Connection pool (see references/database.md — size via Little's Law, don't guess)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_ACQUIRE_TIMEOUT_S=2
DB_POOL_RECYCLE_S=1800

# Redis (rate limiting state + BFF session/token cache, see references/auth.md)
REDIS_URL=redis://localhost:6379

# Auth (BFF pattern: tokens live server-side, browser only gets a session cookie)
OAUTH_ISSUER=https://your-idp.example.com
OAUTH_CLIENT_ID=change-me
OAUTH_CLIENT_SECRET=change-me
SESSION_COOKIE_SECRET=change-me-32-bytes-min
JWKS_URI=https://your-idp.example.com/.well-known/jwks.json

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info
