ENVIRONMENT=development

# Serverless-friendly Postgres driver (HTTP/edge-compatible) — do NOT open a raw TCP pool
# per invocation. See references/architecture-archetypes.md #3 and references/database.md.
DATABASE_URL=postgresql://user:password@your-serverless-pg-host/app_db?sslmode=require

REDIS_URL=rediss://your-managed-redis

OAUTH_ISSUER=https://your-idp.example.com
JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
SESSION_COOKIE_SECRET=change-me-32-bytes-min
