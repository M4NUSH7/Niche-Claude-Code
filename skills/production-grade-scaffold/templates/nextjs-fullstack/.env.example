NODE_ENV=development

# Database (see database/ layer — never commit real credentials)
DATABASE_URL=postgresql://user:password@localhost:5432/app_db?schema=public
DB_POOL_MIN=2
DB_POOL_MAX=10

# Auth (Server Actions/Route Handlers hold the session; use next-auth or a BFF-style cookie session)
OAUTH_ISSUER=https://your-idp.example.com
OAUTH_CLIENT_ID=change-me
OAUTH_CLIENT_SECRET=change-me
SESSION_COOKIE_SECRET=change-me-32-bytes-min
JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
