{
  "_note": "Starting shape for .claude/settings.json. Run `<verified-python> harness/sync_harness.py` after copying - it stamps model IDs, efforts, the hook interpreter, the agents map, and the skills registry from harness/harness.config.json, and derives .agents/settings.json from this file. NEVER hand-edit the stamped fields.",

  "model": "STAMPED-BY-SYNC",

  "_attributionNote": "Claude does NOT tag itself as a contributor by default. `attribution.commit`/`pr` set to \"\" removes the Co-Authored-By trailer and the PR attribution line. (`includeCoAuthoredBy` is the deprecated spelling - `attribution` supersedes it.) Set a string here if you WANT attribution back.",
  "attribution": {
    "commit": "",
    "pr": ""
  },

  "_permissionsNote": "Deliberately conservative. `deny` beats `ask` beats `allow`. The deny list is the point: destructive git, secret reads, and rm -rf are blocked outright - an agent should never need them, and a harness that ships Bash(*) with an empty deny list is handing out root and calling it a default. /init-harness ASKS which profile you want; this is the balanced one.",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(*)", "Glob(*)", "Grep(*)",
      "Edit(*)", "Write(*)",
      "Bash(git status*)", "Bash(git diff*)", "Bash(git log*)", "Bash(git show*)",
      "Bash(git add*)", "Bash(git commit*)", "Bash(git branch*)", "Bash(git checkout*)",
      "Bash(git tag*)", "Bash(git stash*)", "Bash(git fetch*)", "Bash(git pull*)",
      "Bash(ls*)", "Bash(cat*)", "Bash(head*)", "Bash(tail*)", "Bash(wc*)",
      "Bash(mkdir*)", "Bash(cp*)", "Bash(mv*)", "Bash(find*)", "Bash(which*)",
      "Bash(rtk*)", "Bash(sqlite3*)", "Bash(jq*)",
      "WebFetch(*)", "WebSearch(*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(git merge*)",
      "Bash(rm*)",
      "Bash(npm*)", "Bash(pnpm*)", "Bash(yarn*)", "Bash(pip*)", "Bash(cargo*)", "Bash(uv*)",
      "Bash(scoop*)", "Bash(choco*)", "Bash(brew*)",
      "Bash(docker*)", "Bash(gh*)", "Bash(curl*)", "Bash(wget*)"
    ],
    "deny": [
      "Bash(rm -rf /*)", "Bash(rm -rf ~*)",
      "Bash(git push --force*)", "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fdx*)",
      "Bash(git tag -d*)",
      "Bash(git push origin --delete*)",
      "Bash(:(){ :|:& };:*)",
      "Read(**/.env)", "Read(**/.env.local)", "Read(**/.env.*.local)",
      "Read(**/*.pem)", "Read(**/*.key)", "Read(**/id_rsa*)", "Read(**/.ssh/**)",
      "Read(**/credentials*)", "Read(**/.aws/**)",
      "Edit(.agents/**)", "Write(.agents/**)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [{ "type": "command", "command": "STAMPED-BY-SYNC .claude/hooks/big_read_guard.py" }]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [{ "type": "command", "command": "STAMPED-BY-SYNC .claude/hooks/gate_guard.py" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [{ "type": "command", "command": "STAMPED-BY-SYNC .claude/hooks/log_tool_use.py" }]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "STAMPED-BY-SYNC .claude/hooks/fold_logs.py" }]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "STAMPED-BY-SYNC harness/harness_status.py --brief" }]
      }
    ]
  },

  "agents": { "_stamped": "by sync_harness.py from harness.config.json agents{}" },

  "skills": { "_stamped": "by sync_harness.py from harness.config.json skills{}" }
}
